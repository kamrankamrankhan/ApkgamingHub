// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  avatar        String?
  username      String   @unique
  password      String
  twists        Int      @default(10000)
  level         Int      @default(1)
  xp            Int      @default(0)
  vipStatus     String   @default("Bronze") // Bronze, Silver, Gold, Platinum, Diamond
  vipPoints     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  favorites     Favorite[]
  transactions  Transaction[]
  gameSessions  GameSession[]
}

model Game {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  description   String?  @db.Text
  thumbnail     String
  bannerImage   String?
  category      String   // slots, casino, skill, bingo, poker
  provider      String   @default("APKgaminghub")
  isFeatured    Boolean  @default(false)
  isNew         Boolean  @default(false)
  isPopular     Boolean  @default(false)
  minBet        Int      @default(10)
  maxBet        Int      @default(10000)
  jackpot       Int?
  rtp           Float?
  volatility    String?  // low, medium, high
  features      String?  @db.Text // JSON string of features
  paylines      Int?
  reels         Int?
  downloadLink  String?  @db.Text
  
  // Blog Content Fields
  gameOverview          String?  @db.Text
  howToPlay             String?  @db.Text
  tipsAndStrategies     String?  @db.Text // JSON array
  gameHistory           String?  @db.Text
  howToCreateAccount    String?  @db.Text
  conclusion            String?  @db.Text
  faqs                  String?  @db.Text // JSON array
  howToDownloadAndInstall String? @db.Text
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  favorites     Favorite[]
  sessions      GameSession[]
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  gameId    String
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  
  @@unique([userId, gameId])
}

model Transaction {
  id          String   @id @default(cuid())
  userId      String
  type        String   // deposit, withdrawal, bonus, win, loss, daily_bonus, purchase
  amount      Int
  description String?
  status      String   @default("completed") // pending, completed, failed
  createdAt   DateTime @default(now())
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GameSession {
  id          String   @id @default(cuid())
  userId      String
  gameId      String
  betAmount   Int
  winAmount   Int
  outcome     String   // win, loss, draw
  createdAt   DateTime @default(now())
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  game        Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
}

model Promotion {
  id          String   @id @default(cuid())
  title       String
  description String    @db.Text
  image       String?
  bonusType   String   // daily, weekly, vip, welcome
  bonusAmount Int
  minDeposit  Int?
  expiresAt   DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Banner {
  id          String   @id @default(cuid())
  title       String
  subtitle    String?   @db.Text
  image       String
  link        String?
  buttonText  String?
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model HeroBanner {
  id          String   @id @default(cuid())
  title       String
  subtitle    String    @db.Text
  cta         String   @default("Explore") // Call to action button text
  gradient    String   @default("from-yellow-500 via-orange-500 to-red-500")
  imageUrl    String?
  linkUrl     String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
